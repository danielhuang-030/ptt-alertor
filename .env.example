# Ptt-Alertor Service Configuration
PTT_ALERTOR_HOST_PORT=9090
GOPS_HOST_PORT=6060

# Redis Service Configuration
# Used if BOARD_DRIVER_TYPE="redis" (which is the default if BOARD_DRIVER_TYPE is not set)
# or for caching (BOARD_CACHER_TYPE defaults to "redis"). This is a CRITICAL setting if using Redis.
REDIS_HOST_PORT=6379

# Board Data Storage Configuration
# Specifies the driver for storing board main data (articles, etc.).
# Options: "file", "redis", "dynamodb".
# If not set, defaults to "redis".
# For "dynamodb", ensure AWS credentials (AWS_REGION, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY) are configured in your environment.
# For "redis" (including default), ensure REDIS_HOST_PORT is correctly set.
# For "file", ensure BOARD_FILE_STORAGE_PATH is considered.
BOARD_DRIVER_TYPE=redis

# Specifies the storage path for board data files when BOARD_DRIVER_TYPE is "file".
# If not set, a default path (e.g., ./storage/board_articles/) will be used.
BOARD_FILE_STORAGE_PATH=

# Ptt-Alertor Authentication
# IMPORTANT: Change AUTH_PW to a strong, unique password in your actual .env file!
AUTH_USER=admin
AUTH_PW=admin_password

# Ptt-Alertor Channel Tokens (Update with your actual tokens in your .env file)
TELEGRAM_TOKEN=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_TOKEN=
MESSENGER_ACCESS_TOKEN=
MESSENGER_VERIFY_TOKEN=
MESSENGER_APP_SECRET=
DISCORD_WEBHOOK=

# Add any other environment variables required by Ptt-Alertor below
# EXAMPLE_VAR=example_value

# AWS Configuration (Required if BOARD_DRIVER_TYPE="dynamodb")
# Ensure these are set in your environment (e.g., via IAM roles, or directly)
# AWS_REGION=your-aws-region
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Discord Bot Token (Required for Discord bot interactions and notifications via bot)
DISCORD_BOT_TOKEN=

# Default Discord Channel ID (Required for bot commands and as a fallback for notifications)
DISCORD_CHANNEL_ID=

# Optional: Discord Webhook URL (For sending messages via a specific webhook, independent of the bot token)
# DISCORD_WEBHOOK_URL=
