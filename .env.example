# Ptt-Alertor Service Configuration
PTT_ALERTOR_HOST_PORT=9090
GOPS_HOST_PORT=6060

# Redis Service Configuration
REDIS_HOST_PORT=6379

# Ptt-Alertor Authentication
# IMPORTANT: Change AUTH_PW to a strong, unique password in your actual .env file!
AUTH_USER=admin
AUTH_PW=admin_password

# Ptt-Alertor Channel Tokens (Update with your actual tokens in your .env file)
TELEGRAM_TOKEN=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_TOKEN=
MESSENGER_ACCESS_TOKEN=
MESSENGER_VERIFY_TOKEN=
MESSENGER_APP_SECRET=
DISCORD_WEBHOOK=

# Add any other environment variables required by Ptt-Alertor below
# EXAMPLE_VAR=example_value

# Discord Bot Token (Required for Discord bot interactions and notifications via bot)
DISCORD_BOT_TOKEN=

# Default Discord Channel ID (Required for bot commands and as a fallback for notifications)
DISCORD_CHANNEL_ID=

# Optional: Discord Webhook URL (For sending messages via a specific webhook, independent of the bot token)
# DISCORD_WEBHOOK_URL=
